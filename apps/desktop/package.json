{
	"name": "koins",
	"private": true,
	"type": "module",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:dev": "vite build && electrobun build",
		"build:canary": "vite build && electrobun build --env=canary",
		"build:stable": "vite build && electrobun build --env=stable",
		"db:push": "bun x --bun drizzle-kit push",
		"db:generate": "drizzle-kit generate"
	},
	"dependencies": {
		"@alchemy/wallet-apis": "^5.0.0-beta.28",
		"@koins/utils": "workspace:*",
		"drizzle-orm": "^1.0.0-beta.22",
		"electrobun": "^1.18.1",
		"ethers": "^6.16.0",
		"mode-watcher": "^1.1.0",
		"sv-router": "latest",
		"viem": "^2.48.11"
	},
	"devDependencies": {
		"@fontsource-variable/geist-mono": "^5.2.7",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.7.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/table-core": "^8.21.3",
		"@types/env-paths": "^2.1.2",
		"@types/node": "^25.7.0",
		"bits-ui": "^2.16.5",
		"bun-types": "^1.3.14",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^1.0.0-beta.22",
		"embla-carousel-svelte": "^8.6.0",
		"formsnap": "^2.0.1",
		"layerchart": "2.0.0-next.48",
		"paneforge": "^1.0.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"remixicon-svelte": "^0.0.5",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.3",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^8.0.8"
	}
}
